# Resend — contact form email delivery
# Get a key at https://resend.com/api-keys
RESEND_API_KEY=

# Where contact submissions are delivered
CONTACT_TO=ilija@undertheradar.agency

# Sender. Until undertheradar.agency is verified in Resend, leave this on
# the shared sender below. After verifying the domain, switch to something
# like: Under the Radar <noreply@undertheradar.agency>
CONTACT_FROM=Under the Radar <onboarding@resend.dev>
